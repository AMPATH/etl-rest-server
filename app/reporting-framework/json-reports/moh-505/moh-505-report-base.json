    {
      "type": "derived_column",
      "alias": "age_range",
      "expressionType": "case_statement",
      "expressionOptions": {
        "caseOptions": [
          {
            "condition": "fm.age < 5",
            "value": "0_to_4"
          },
          {
            "condition": "fm.age >= 5",
            "value": "5_and_above"
          }
        ]
      }
    }
