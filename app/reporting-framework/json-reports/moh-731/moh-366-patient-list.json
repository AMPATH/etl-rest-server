{
  "name": "moh_366_patient_list_template",
  "version": "1.0",
  "tag": "moh_366_patient_list_template",
  "description": "MOH 366 Patient list template",
  "sources": [
    {
      "table": "amrs.person",
      "alias": "person"
    },
    {
      "table": "etl.flat_hiv_summary_v15b",
      "alias": "a",
      "join": {
        "type": "LEFT",
        "joinCondition": "person.person_id = a.person_id"
      }
    },
    {
      "table": "amrs.encounter",
      "alias": "en",
      "join": {
        "type": "LEFT",
        "joinCondition": "en.encounter_id = a.encounter_id"
      }
    },
    {
      "table": "amrs.location",
      "alias": "l",
      "join": {
        "type": "LEFT",
        "joinCondition": "l.location_id = en.location_id"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "b",
      "join": {
        "type": "LEFT",
        "joinCondition": "b.patient_id = a.person_id AND b.identifier_type = 5"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "c",
      "join": {
        "type": "LEFT",
        "joinCondition": "c.patient_id = a.person_id AND c.identifier_type = 45"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "d",
      "join": {
        "type": "LEFT",
        "joinCondition": "d.patient_id = a.person_id AND d.identifier_type = 28"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "g",
      "join": {
        "type": "LEFT",
        "joinCondition": "g.patient_id = a.person_id AND g.identifier_type = 8"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "dsd",
      "join": {
        "type": "LEFT",
        "joinCondition": "dsd.encounter_id = a.encounter_id AND dsd.concept_id IN (11931,11932)"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "obs1",
      "join": {
        "type": "LEFT",
        "joinCondition": "obs1.encounter_id = a.encounter_id AND obs1.concept_id in (12108)"
      }
    },
    {
      "table": "amrs.person_name",
      "alias": "person_name",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = person_name.person_id AND (person_name.voided IS NULL || person_name.voided = 0) AND person_name.preferred = 1"
      }
    },
    {
      "table": "amrs.person_attribute",
      "alias": "attribute",
      "join": {
        "type": "LEFT",
        "joinCondition": "attribute.person_id = a.person_id AND attribute.person_attribute_type_id = 10"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "amrs",
      "join": {
        "type": "INNER",
        "joinCondition": "a.person_id = amrs.patient_id AND (amrs.voided IS NULL || amrs.voided = 0) AND amrs.identifier_type = 8"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "obs",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = obs.person_id AND obs.concept_id in (10926, 10927, 2327, 12019)"
      }
    },
    {
      "table": "(SELECT o.person_id, o.value_text FROM amrs.obs o INNER JOIN (SELECT person_id, MAX(CONCAT(obs_datetime, LPAD(obs_id, 10, '0'))) AS max_key FROM amrs.obs WHERE concept_id = 7222 GROUP BY person_id) latest ON latest.person_id = o.person_id AND latest.max_key = CONCAT(o.obs_datetime, LPAD(o.obs_id, 10, '0')) WHERE o.concept_id = 7222)",
      "alias": "oa_latest",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = oa_latest.person_id"
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "a.person_id"
    },
    {
      "type": "simple_column",
      "alias": "date",
      "column": "a.encounter_datetime"
    },
    {
      "type": "simple_column",
      "alias": "rtc_date",
      "column": "a.rtc_date"
    },
    {
      "type": "simple_column",
      "alias": "national_id_number",
      "column": "b.identifier"
    },
    {
      "type": "simple_column",
      "alias": "NUPI",
      "column": "c.identifier"
    },
    {
      "type": "simple_column",
      "alias": "ccc_number",
      "column": "d.identifier"
    },
    {
      "type": "simple_column",
      "alias": "amrsID",
      "column": "d.identifier"
    },
    {
      "type": "derived_column",
      "alias": "age",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "timestampdiff(year, person.birthdate, a.encounter_datetime) "
      }
    },
    {
      "type": "simple_column",
      "alias": "gender",
      "column": "person.gender"
    },
    {
      "type": "derived_column",
      "alias": "started_on_art",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "case when a.encounter_type = 1 then 'Y' else 'N' end"
      }
    },
    {
      "type": "derived_column",
      "alias": "screened_for_tb",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "case when a.tb_screen = 1 THEN 'Y' when a.tb_screen = 0 THEN 'N' else '' end"
      }
    },
    {
      "type": "derived_column",
      "alias": "started_on_tpt",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "case when a.on_ipt = 1 THEN 'Y' when a.on_ipt = 0 THEN 'N' else '' end"
      }
    },
    {
      "type": "derived_column",
      "alias": "current_on_art",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "timestampdiff(month, a.encounter_datetime, a.rtc_date)"
      }
    },
    {
      "type": "derived_column",
      "alias": "dsd_status",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "case when obs1.value_coded = 12106 THEN 'E' when obs1.value_coded = 12107 THEN 'NE' else '' end"
      }
    },
    {
      "type": "derived_column",
      "alias": "dsd_type",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "case when dsd.value_coded = 11936 THEN 'FT' when dsd.value_coded = 11937 THEN 'HFAG' when dsd.value_coded = 11939 THEN 'IACD'  when dsd.value_coded = 11940 THEN 'CADP' when dsd.value_coded = 10992 THEN 'PCAG' when dsd.value_coded =  10991 THEN 'HCAG' when dsd.value_coded =  11938 THEN 'CADP' else '' end"
      }
    },
    {
      "type": "derived_column",
      "alias": "revisit",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "case WHEN  a.next_encounter_type_hiv != 99999 AND a.encounter_type = 1 THEN 'R' else null end"
      }
    },
    {
      "type": "derived_column",
      "alias": "remarks",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "TRIM(SUBSTRING_INDEX(REPLACE(REPLACE(REPLACE(oa_latest.value_text, '\r\n', '\n'),',', '\n'),'.', '\n'),'\n', 1))"
      }
    }
  ],
  "groupBy": {
    "columns": ["a.person_id", "a.encounter_id", "o.concept_id"]
  },
  "orderBy": {
    "orderByParam": "orderByParam",
    "columns": [
      {
        "column": "a.encounter_datetime",
        "order": "desc"
      }
    ]
  }
}
