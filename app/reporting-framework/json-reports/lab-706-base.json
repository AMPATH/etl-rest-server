        "parameterName": "startDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "fbc.test_datetime <= ?",
        "parameterName": "endDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "l.uuid in ?",
