      "table": "etl.flat_blood_chemistry",
      "alias": "fbc"
    },
    {
      "table": "amrs.location",
      "alias": "l",
      "join": {
        "type": "INNER",
        "joinCondition": "fbc.location_id = l.location_id"
      }
    },
    {
      "table": "amrs.person",
      "alias": "p",
      "join": {
        "type": "INNER",
        "joinCondition": "fbc.person_id = p.person_id"
      }
    }
