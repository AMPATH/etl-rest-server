{
  "name": "moh_710_patient_list_template",
  "version": "1.0",
  "tag": "moh_710_patient_list_template",
  "description": "MOH 710 Patient list template",
  "sources": [
    {
      "table": "amrs.person",
      "alias": "t1"
    },
    {
      "table": "amrs.person_name",
      "alias": "person_name",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = person_name.person_id AND (person_name.voided IS NULL || person_name.voided = 0) AND person_name.preferred = 1"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "id",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = id.patient_id AND (id.voided IS NULL || id.voided = 0) AND id.identifier_type not in(28,43,45)"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "category",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = category.person_id AND category.concept_id = 12108"
      }
    },
    {
      "table": "amrs.person_attribute",
      "alias": "contacts",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = contacts.person_id AND (contacts.voided IS NULL || contacts.voided = 0) AND contacts.person_attribute_type_id in (10, 48)"
      }
    },
    {
      "table": "etl.flat_hiv_summary_v15b",
      "alias": "fh",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = fh.person_id AND fh.next_clinical_datetime_hiv IS NULL AND fh.is_clinical_encounter = 1"
      }
    },
    {
      "table": "amrs.encounter_type",
      "alias": "et",
      "join": {
        "type": "LEFT",
        "joinCondition": "fh.encounter_type = et.encounter_type_id"
      }
    },
    {
      "table": "amrs.person_address",
      "alias": "pa",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = pa.person_id"
      }
    },
    {
      "table": "etl.flat_covid_extract",
      "alias": "c",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = c.person_id AND c.next_encounter_datetime IS NULL"
      }
    },
    {
      "table": "etl.flat_consent",
      "alias": "consent",
      "join": {
        "type": "LEFT",
        "joinCondition": "consent.person_id = t1.person_id"
      }
    },
    {
      "table": " etl.flat_cervical_cancer_screening_rc",
      "alias": "cs",
      "join": {
        "type": "LEFT",
        "joinCondition": "cs.person_id = t1.person_id AND cs.next_clinical_datetime_cervical_cancer_screening IS NULL "
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "patient_uuid",
      "column": "t1.uuid"
    },
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "t1.person_id"
    },
    {
      "type": "derived_column",
      "alias": "full_name",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": " CONCAT_WS(' ', COALESCE(person_name.given_name, ''), COALESCE(person_name.middle_name, ''), COALESCE(person_name.family_name, ''))"
      }
    },
    {
      "type": "derived_column",
      "alias": "identifiers",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": " GROUP_CONCAT(DISTINCT id.identifier SEPARATOR ', ')"
      }
    },
    {
      "type": "derived_column",
      "alias": "phone_number",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": " GROUP_CONCAT(DISTINCT contacts.value SEPARATOR ', ')"
      }
    },
    {
      "type": "simple_column",
      "alias": "cwc_number",
      "column": ""
    },
    {
      "type": "simple_column",
      "alias": "birth_notification_number",
      "column": ""
    },
    {
      "type": "simple_column",
      "alias": "age",
      "column": ""
    },
    {
      "type": "simple_column",
      "alias": "sex",
      "column": "t1.gender"
    },
    {
      "type": "simple_column",
      "alias": "county_sub_county",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "village_estate_landmark",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "weight_kg",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "weight_category",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "height",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "height_category",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "muac",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "exclusive_breastfeeding_less_6_months",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "vitamin_A_supplementation",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "dewormed",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "mnps_supplimentation",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "developmental_milestones",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "disability",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "immunization_status_up_to_date",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "llin_supplimentation_given",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "follow_up",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "referred_from",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "referred_to",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "reason_for_referral",
      "column": "fh.hiv_disclosure_status_value"
    },
    {
      "type": "simple_column",
      "alias": "remarks",
      "column": "fh.hiv_disclosure_status_value"
    }
  ],
  "groupBy": {
    "columns": ["t1.person_id"]
  }
}
