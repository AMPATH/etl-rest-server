  "uses": [],
  "sources": [
    {
      "table": "amrs.obs",
      "alias": "o"
    },
    {
      "table": "amrs.obs",
      "alias": "obs",
      "join": {
        "type": "INNER",
        "joinCondition": "o.encounter_id = obs.encounter_id AND obs.obs_group_id = o.obs_group_id AND obs.voided = 0 AND obs.value_numeric IS NOT NULL AND obs.concept_id = 10888"
      }
    },
    {
      "table": "amrs.encounter",
      "alias": "e",
      "join": {
        "type": "INNER",
        "joinCondition": "e.encounter_id = o.encounter_id AND e.voided = 0 AND o.concept_id in (984, 10936, 9612, 2300)"
      }
    },
    {
      "table": "amrs.person",
      "alias": "p",
      "join": {
        "type": "INNER",
        "joinCondition": "o.person_id = p.person_id AND p.voided = 0"
      }
    },
    {
      "table": "amrs.location",
      "alias": "l",
      "join": {
        "type": "INNER",
        "joinCondition": "l.location_id = o.location_id"
      }
    }
