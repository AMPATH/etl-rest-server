{
  "name": "tetanusBase",
  "version": "1.0",
  "tag": "",
  "description": "",
  "uses": [],
  "sources": [
    {
      "table": "amrs.obs",
      "alias": "o"
    },
    {
      "table": "amrs.obs",
      "alias": "ob1",
      "join": {
        "type": "INNER",
        "joinCondition": "ob1.encounter_id = o.encounter_id AND ob1.voided = 0"
      }
    },
    {
      "table": "amrs.encounter",
      "alias": "e",
      "join": {
        "type": "INNER",
        "joinCondition": "e.encounter_id = o.encounter_id AND e.voided = 0"
      }
    },
    {
      "table": "amrs.person",
      "alias": "p",
      "join": {
        "type": "INNER",
        "joinCondition": "o.person_id = p.person_id AND p.voided = 0 AND o.concept_id in (10404, 12059)"
      }
    },
    {
      "table": "amrs.location",
      "alias": "l",
      "join": {
        "type": "INNER",
        "joinCondition": "l.location_id = o.location_id"
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "obs_datetime",
      "column": "o.obs_datetime"
    },
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "o.person_id"
    },
    {
      "type": "simple_column",
      "alias": "age",
      "column": "TIMESTAMPDIFF(YEAR, p.birthdate, CURDATE())"
    },
    {
      "type": "derived_column",
      "alias": "tetanus_toxoid1",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "if(o.concept_id = 10404 AND o.value_coded = 8009, 1, 0)"
      }
    },
    {
      "type": "derived_column",
      "alias": "tetanus_toxoid2",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "if(o.concept_id = 10404 AND o.value_coded = 8010, 1, 0)"
      }
    },
    {
      "type": "derived_column",
      "alias": "tetanus_toxoid3",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "if(o.concept_id = 10404 AND o.value_coded = 8011, 1, 0)"
      }
    },
    {
      "type": "derived_column",
      "alias": "tetanus_toxoid4",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "if(o.concept_id = 10404 AND o.value_coded = 8012, 1, 0)"
      }
    },
    {
      "type": "derived_column",
      "alias": "tetanus_toxoid5",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "if(o.concept_id = 10404 AND o.value_coded = 8013, 1, 0)"
      }
    },
    {
      "type": "derived_column",
      "alias": "hpv_vaccine1",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "if(o.concept_id = 12059 AND o.value_coded = 1065, 1, 0)"
      }
    },
    {
      "type": "derived_column",
      "alias": "hpv_vaccine2",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "if(o.concept_id = 12059 AND o.value_coded = 1065, 1, 0)"
      }
    }
  ],
  "filters": {
    "conditionJoinOperator": "and",
    "conditions": [
      {
        "filterType": "tableColumns",
        "conditionExpression": "e.encounter_type in (265, 313)"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "DATE(o.obs_datetime) >= ?",
        "parameterName": "startDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "DATE(o.obs_datetime) <= ?",
        "parameterName": "endDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "o.location_id in ?",
        "parameterName": "locations"
      }
    ]
  },
  "groupBy": {
    "groupParam": "groupByParam",
    "columns": ["o.person_id"]
  }
}
