    {
      "table": "amrs.encounter",
      "alias": "e",
      "join": {
        "type": "INNER",
        "joinCondition": "e.encounter_id = ed.encounter_id AND e.voided = 0"
      }
    },
    {
      "table": "amrs.person",
      "alias": "p",
      "join": {
        "type": "INNER",
        "joinCondition": "ed.patient_id = p.person_id AND p.voided = 0"
      }
    },
    {
      "table": "amrs.location",
