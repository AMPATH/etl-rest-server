      "alias": "lab_special_test",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "plain_xray_without_enhancement",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "contrast_enhancement_examination",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "magnetic_resonance_imaging",
      "column": "null"
    },
    {
