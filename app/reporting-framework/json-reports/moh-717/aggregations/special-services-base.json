      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "number_of_ultrasound_examinations",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "general_ultrasound",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "obstetric_ultrasound",
      "column": "null"
