{
  "name": "dentalBase",
  "version": "1.0",
  "tag": "",
  "description": "",
  "uses": [],
  "sources": [
    {
      "table": "amrs.obs",
      "alias": "o"
    },
    {
      "table": "amrs.encounter",
      "alias": "e",
      "join": {
        "type": "INNER",
        "joinCondition": "e.encounter_id = o.encounter_id AND e.voided = 0 AND e.encounter_type IN (329)"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "obs",
      "join": {
        "type": "LEFT",
        "joinCondition": "o.person_id = obs.person_id"
      }
    },
    {
      "table": "amrs.person",
      "alias": "p",
      "join": {
        "type": "INNER",
        "joinCondition": "o.person_id = p.person_id AND p.voided = 0"
      }
    },
    {
      "table": "amrs.location",
      "alias": "l",
      "join": {
        "type": "INNER",
        "joinCondition": "l.location_id = o.location_id"
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "obs_datetime",
      "column": "o.obs_datetime"
    },
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "o.person_id"
    },
    {
      "type": "simple_column",
      "alias": "dental_attendance_ex_fillings_extractions_new",
      "column": "if(o.concept_id = 1839 AND o.value_coded = 7850, 1, NULL)"
    },
    {
      "type": "simple_column",
      "alias": "dental_attendance_ex_fillings_extractions_revisit",
      "column": "if(o.concept_id = 1839 AND o.value_coded = 11233, 1, NULL)"
    },
    {
      "type": "simple_column",
      "alias": "dental_fillings_new",
      "column": "if(o.concept_id = 1840 AND o.value_coded = 7850, 1, NULL)"
    },
    {
      "type": "simple_column",
      "alias": "dental_fillings_revisit",
      "column": "if(o.concept_id = 1840 AND o.value_coded = 11233, 1, NULL)"
    },
    {
      "type": "simple_column",
      "alias": "dental_extractions_new",
      "column": "if(o.concept_id = 1841 AND o.value_coded = 7850, 1, NULL)"
    },
    {
      "type": "simple_column",
      "alias": "dental_extractions_revisit",
      "column": "if(o.concept_id = 1841 AND o.value_coded = 11233, 1, NULL)"
    }
  ],
  "filters": {
    "conditionJoinOperator": "and",
    "conditions": [
      {
        "filterType": "tableColumns",
        "conditionExpression": "e.encounter_type in (329)"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "o.obs_datetime >= ?",
        "parameterName": "startDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "o.obs_datetime <= ?",
        "parameterName": "endDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "o.location_id in ?",
        "parameterName": "locations"
      }
    ]
  },
  "groupBy": {
    "groupParam": "groupByParam",
    "columns": ["o.person_id"]
  }
}
