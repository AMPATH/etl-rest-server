{
  "name": "medicalRecordsBase",
  "version": "1.0",
  "tag": "",
  "description": "",
  "uses": [],
  "sources": [
    {
      "table": "amrs.obs",
      "alias": "o"
    },
    {
      "table": "amrs.obs",
      "alias": "obs",
      "join": {
        "type": "LEFT",
        "joinCondition": "o.person_id = obs.person_id"
      }
    },
    {
      "table": "amrs.person",
      "alias": "p",
      "join": {
        "type": "INNER",
        "joinCondition": "o.person_id = p.person_id AND p.voided = 0"
      }
    },
    {
      "table": "amrs.location",
      "alias": "l",
      "join": {
        "type": "INNER",
        "joinCondition": "l.location_id = o.location_id"
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "obs_datetime",
      "column": "o.obs_datetime"
    },
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "o.person_id"
    },
    {
      "type": "simple_column",
      "alias": "new_patient_files_issued",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "outpatient_records_cards_issued",
      "column": "null"
    }
  ],
  "filters": {
    "conditionJoinOperator": "and",
    "conditions": [
      {
        "filterType": "tableColumns",
        "conditionExpression": "o.obs_datetime >= ?",
        "parameterName": "startDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "o.obs_datetime <= ?",
        "parameterName": "endDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "o.location_id in ?",
        "parameterName": "locations"
      }
    ]
  },
  "groupBy": {
    "groupParam": "groupByParam",
    "columns": ["o.person_id"]
  }
}
