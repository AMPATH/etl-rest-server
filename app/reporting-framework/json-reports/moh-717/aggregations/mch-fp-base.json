{
  "name": "mchFPBase",
  "version": "1.0",
  "tag": "",
  "description": "",
  "uses": [],
  "sources": [
    {
      "table": "amrs.encounter",
      "alias": "e"
    },
    {
      "table": "amrs.obs",
      "alias": "o",
      "join": {
        "type": "LEFT",
        "joinCondition": "e.encounter_id = o.encounter_id AND e.voided = 0"
      }
    },
    {
      "table": "amrs.location",
      "alias": "l",
      "join": {
        "type": "INNER",
        "joinCondition": "l.location_id = e.location_id"
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "obs_datetime",
      "column": "o.obs_datetime"
    },
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "o.person_id"
    },
    {
      "type": "simple_column",
      "alias": "concept_id",
      "column": "o.concept_id"
    },
    {
      "type": "simple_column",
      "alias": "encounter_type",
      "column": "e.encounter_type"
    },
    {
      "type": "simple_column",
      "alias": "cwc_attendance_new",
      "column": "SUM(DISTINCT if(e.encounter_type = 167 AND (o.concept_id = 1839 AND o.value_coded = 7850), 1, 0))"
    },
    {
      "type": "simple_column",
      "alias": "cwc_attendance_revisit",
      "column": "SUM(DISTINCT if(e.encounter_type = 167 AND (o.concept_id = 1839 AND o.value_coded = 11233), 1, 0))"
    },
    {
      "type": "simple_column",
      "alias": "anc_new",
      "column": "SUM(DISTINCT if(e.encounter_type = 264, 1, 0))"
    },
    {
      "type": "simple_column",
      "alias": "anc_revisit",
      "column": "SUM(DISTINCT if(e.encounter_type = 265, 1, 0))"
    },
    {
      "type": "simple_column",
      "alias": "pnc_new",
      "column": "SUM(DISTINCT if(e.encounter_type = 266, 1, 0))"
    },
    {
      "type": "simple_column",
      "alias": "pnc_revisit",
      "column": "SUM(DISTINCT if(e.encounter_type = 267, 1, 0))"
    },
    {
      "type": "simple_column",
      "alias": "fp_attendance_new",
      "column": "SUM(if(o.concept_id = 1724 AND o.value_coded = 10647, 1, 0))"
    },
    {
      "type": "simple_column",
      "alias": "fp_attendance_revisit",
      "column": "SUM(if(o.concept_id = 1724 AND o.value_coded = 2345, 1, 0))"
    }
  ],
  "filters": {
    "conditionJoinOperator": "and",
    "conditions": [
      {
        "filterType": "tableColumns",
        "conditionExpression": "e.encounter_type in (179,264,265,266,267,167)"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "e.encounter_datetime >= ?",
        "parameterName": "startDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "e.encounter_datetime <= ?",
        "parameterName": "endDate"
      },
      {
        "filterType": "tableColumns",
        "conditionExpression": "l.location_id in (?)",
        "parameterName": "locations"
      }
    ]
  },
  "groupBy": {
    "groupParam": "groupByParam",
    "columns": ["e.patient_id", "e.encounter_type"]
  }
}
