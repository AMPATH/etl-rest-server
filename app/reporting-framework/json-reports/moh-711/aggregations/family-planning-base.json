{
  "name": "familyPlanningBase",
  "version": "1.0",
  "tag": "",
  "description": "",
  "uses": [],
  "sources": [
    {
      "table": "amrs.obs",
      "alias": "o"
    },
    {
      "table": "amrs.obs",
      "alias": "ob",
      "join": {
        "type": "LEFT",
        "joinCondition": "ob.encounter_id = o.encounter_id AND ob.voided = 0 AND ob.concept_id = 1724 "
      }
    },
    {
      "table": "amrs.encounter",
      "alias": "e",
      "join": {
        "type": "INNER",
        "joinCondition": "e.encounter_id = o.encounter_id AND e.voided = 0"
      }
    },
    {
      "table": "etl.flat_patient_identifiers_v1",
      "alias": "flat_identifiers",
      "join": {
        "type": "LEFT",
        "joinCondition": "o.person_id = flat_identifiers.patient_id"
      }
    },
    {
      "table": "amrs.person",
      "alias": "p",
      "join": {
        "type": "INNER",
        "joinCondition": "o.person_id = p.person_id AND p.voided = 0"
      }
    }
  ],
