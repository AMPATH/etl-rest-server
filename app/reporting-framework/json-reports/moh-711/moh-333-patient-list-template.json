      "column": "a.anc_visit_no"
    },
    {
      "type": "simple_column",
      "alias": "lmp",
      "column": "a.last_lmp_date"
    },
    {
      "type": "simple_column",
      "alias": "edd",
      "column": "a.edd"
    },
    {
      "type": "simple_column",
      "alias": "diagnosis",
      "column": "a.diagnosis"
    },
    {
      "type": "simple_column",
      "alias": "duration_of_labour",
      "column": "a.duration_of_delivery"
    },
    {
      "type": "simple_column",
      "alias": "date_of_delivery",
      "column": "a.day_of_delivery"
    },
    {
      "type": "simple_column",
      "alias": "time_of_delivery",
      "column": "a.time_of_delivery"
    },
    {
      "type": "simple_column",
      "alias": "gestation_at_birth",
      "column": "a.gestation_at_birth"
    },
    {
      "type": "simple_column",
      "alias": "mode_of_delivery",
      "column": "a.mode_of_delivery"
    },
    {
      "type": "simple_column",
      "alias": "no_of_babies_delivered",
      "column": "a.no_of_babies"
    },
    {
      "type": "simple_column",
      "alias": "placenta_complete",
