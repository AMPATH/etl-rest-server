{
  "name": "moh_333_patient_list_template",
  "version": "1.0",
  "tag": "moh_333_patient_list_template",
  "description": "MOH 333 Patient list template",
  "sources": [
    {
      "table": "etl.flat_mnch_summary",
      "alias": "a"
    },
    {
      "table": "amrs.person",
      "alias": "p",
      "join": {
        "type": "LEFT",
        "joinCondition": "p.person_id = a.person_id"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "mat_number",
      "join": {
        "type": "INNER",
        "joinCondition": "mat_number.person_id = a.person_id AND mat_number.identifier_type = 49"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "nupi",
      "join": {
        "type": "INNER",
        "joinCondition": "nupi.person_id = a.person_id AND nupi.identifier_type = 45"
      }
    },
    {
      "table": "amrs.person_name",
      "alias": "person_name",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = person_name.person_id AND (person_name.voided IS NULL || person_name.voided = 0) AND person_name.preferred = 1"
      }
    },
    {
      "table": "amrs.person_attribute",
      "alias": "attribute",
      "join": {
        "type": "LEFT",
        "joinCondition": "attribute.person_id = a.person_id AND attribute.person_attribute_type_id = 10"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "amrs",
      "join": {
        "type": "INNER",
        "joinCondition": "a.person_id = amrs.patient_id AND (amrs.voided IS NULL || amrs.voided = 0) AND amrs.identifier_type = 8"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "obs",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = obs.person_id AND obs.concept_id in (10926, 10927, 2327, 12019)"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "ob",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = ob.person_id AND ob.concept_id = 12019"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "oc",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = oc.person_id AND oc.concept_id = 1357"
      }
    },
    {
      "table": "amrs.person_address",
      "alias": "pa",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = pa.person_id"
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "patient_uuid",
      "column": "p.uuid"
    },
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "a.person_id"
    },
    {
      "type": "derived_column",
      "alias": "identifiers",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": " GROUP_CONCAT(DISTINCT id.identifier SEPARATOR ', ')"
      }
    },
    {
      "type": "simple_column",
      "alias": "admission_date",
      "column": "a.maternity_admission_date"
    },
    {
      "type": "simple_column",
      "alias": "amrs_id",
      "column": "amrs.identifier"
    },
    {
      "type": "simple_column",
      "alias": "mat_number",
      "column": "mat_number.identifier"
    },
    {
      "type": "simple_column",
      "alias": "nupi",
      "column": "nupi.identifier"
    },
    {
      "type": "derived_column",
      "alias": "full_names",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": " CONCAT_WS(' ', COALESCE(person_name.given_name, ''), COALESCE(person_name.middle_name, ''), COALESCE(person_name.family_name, ''))"
      }
    },
    {
      "type": "simple_column",
      "alias": "date_of_birth",
      "column": "p.birthdate"
    },
    {
      "type": "derived_column",
      "alias": "age",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "timestampdiff(year, p.birthdate, a.encounter_datetime) "
      }
    },
    {
      "type": "simple_column",
      "alias": "county_sub_county",
      "column": "pa.county_district"
    },
    {
      "type": "simple_column",
      "alias": "village_estate_landmark",
      "column": "pa.city_village"
    },
    {
      "type": "simple_column",
      "alias": "phone_number",
      "column": "attribute.value"
    },
    {
      "type": "simple_column",
      "alias": "marital_status",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "parity",
      "column": "a.parity"
    },
    {
      "type": "simple_column",
      "alias": "gravidae",
