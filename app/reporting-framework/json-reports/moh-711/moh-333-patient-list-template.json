    {
      "type": "simple_column",
      "alias": "uterotonic_given",
      "column": "a.uterotonic_given"
    },
    {
      "type": "simple_column",
      "alias": "vaginal_examination",
      "column": "a.vaginal_examination"
    },
    {
      "type": "simple_column",
      "alias": "blood_loss",
      "column": "a.blood_loss"
    },
    {
      "type": "simple_column",
