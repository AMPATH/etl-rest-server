{
  "name": "moh_511_patient_list_template",
  "version": "1.0",
  "tag": "moh_511_patient_list_template",
  "description": "MOH 511 Patient list template",
  "sources": [
    {
      "table": "amrs.obs",
      "alias": "obs1"
    },
    {
      "table": "amrs.person",
      "alias": "t1",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = obs1.person_id "
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "cwc_number",
      "join": {
        "type": "LEFT",
        "joinCondition": "cwc_number.patient_id = t1.person_id AND cwc_number.identifier_type = 22"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "nupi",
      "join": {
        "type": "LEFT",
        "joinCondition": "nupi.patient_id = t1.person_id AND nupi.identifier_type = 45"
      }
    },
    {
      "table": "amrs.person_name",
      "alias": "person_name",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = person_name.person_id AND (person_name.voided IS NULL || person_name.voided = 0) AND person_name.preferred = 1"
      }
    },
    {
      "table": "amrs.person_attribute",
      "alias": "attribute",
      "join": {
        "type": "LEFT",
        "joinCondition": "attribute.person_id = t1.person_id AND attribute.person_attribute_type_id = 10"
      }
    },
    {
      "table": "amrs.encounter",
      "alias": "en",
      "join": {
        "type": "LEFT",
        "joinCondition": "en.encounter_id = obs1.encounter_id AND en.encounter_type in (4,110,167,313)"
      }
    },
    {
      "table": "amrs.person_address",
      "alias": "pa",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = pa.person_id"
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "patient_uuid",
      "column": "t1.uuid"
    },
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "t1.person_id"
    },
    {
      "type": "simple_column",
      "alias": "visit_date",
      "column": "obs1.obs_datetime"
    },
    {
      "type": "simple_column",
      "alias": "cwc_number_new",
      "column": "cwc_number.identifier"
    },
    {
      "type": "simple_column",
      "alias": "cwc_number_revisit",
      "column": "cwc_number.identifier"
    },
    {
      "type": "derived_column",
      "alias": "birth_notification_number",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "IF(obs1.concept_id = 8558, obs1.value_text, NULL)"
      }
    },
    {
      "type": "derived_column",
      "alias": "full_name",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": " CONCAT_WS(' ', COALESCE(person_name.given_name, ''), COALESCE(person_name.middle_name, ''), COALESCE(person_name.family_name, ''))"
      }
    },
    {
      "type": "derived_column",
      "alias": "age",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "CONCAT(FLOOR(TIMESTAMPDIFF(MONTH, t1.birthdate, CURDATE()) / 12), ' ', MOD(TIMESTAMPDIFF(MONTH, t1.birthdate, CURDATE()), 12), '/12')"
      }
    },
    {
      "type": "simple_column",
      "alias": "sex",
      "column": "t1.gender"
    },
    {
      "type": "simple_column",
      "alias": "county_sub_county",
      "column": "pa.county_district"
    },
    {
      "type": "simple_column",
      "alias": "village_estate_landmark",
      "column": "pa.city_village"
    },
    {
      "type": "simple_column",
      "alias": "phone_number",
      "column": "attribute.value"
    },
    {
      "type": "derived_column",
      "alias": "weight",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "IF(o.concept_id = 5089, o.value_numeric, NULL)"
      }
    },
    {
      "type": "derived_column",
      "alias": "weight_category",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "IF(obs1.concept_id = 10213, obs1.value_coded, NULL)"
      }
    },
    {
      "type": "derived_column",
      "alias": "height",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "IF(obs1.concept_id = 5090, obs1.value_numeric, NULL)"
      }
    },
    {
      "type": "derived_column",
      "alias": "height_category",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "null"
      }
    },
    {
      "type": "derived_column",
      "alias": "muac",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "IF(obs1.concept_id = 1343, obs1.value_numeric, NULL)"
      }
    },
    {
      "type": "derived_column",
      "alias": "exclusive_breastfeeding_less_6_months",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "IF(obs1.concept_id = 5526 AND obs1.value_coded = 1065, 'Y', 'N')"
      }
    },
    {
      "type": "derived_column",
      "alias": "vitamin_A_supplementation",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "IF(obs1.concept_id = 10936 AND obs1.value_coded = 1065, 'Y', 'N')"
      }
    },
    {
      "type": "derived_column",
      "alias": "dewormed",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "IF(obs1.concept_id = 7404 AND obs1.value_coded = 1065, 'Y', 'N')"
      }
    },
    {
      "type": "derived_column",
      "alias": "mnps_supplimentation",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "IF(obs1.concept_id = 9487 AND obs1.value_coded = 9488, 'Y', 'N')"
      }
    },
    {
      "type": "simple_column",
      "alias": "developmental_milestones",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "danger_signs",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "disability",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "immunization_status_up_to_date",
      "column": "if(obs1.concept_id = 2300 AND obs1.value_coded = 1065, 1, 0)"
    },
    {
      "type": "simple_column",
      "alias": "llin_supplimentation_given",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "follow_up",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "referred_from",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "referred_to",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "remarks",
      "column": "null"
    }
  ],
  "groupBy": {
    "columns": ["obs1.person_id"]
  },
  "filters": {
    "conditionJoinOperator": "and",
    "conditions": [
      {
        "filterType": "tableColumns",
        "conditionExpression": "en.encounter_type in (4,110,167,313)"
      }
    ]
  },
  "orderBy": {
    "orderByParam": "orderByParam",
    "columns": [
      {
        "column": "obs1.obs_datetime",
        "order": "desc"
      }
    ]
  }
}
