    {
      "type": "simple_column",
      "alias": "height",
      "column": "a.height"
    },
    {
      "type": "simple_column",
      "alias": "weight",
      "column": "a.weight"
    },
    {
      "type": "simple_column",
      "alias": "blood_pressure",
      "column": "a.blood_pressure"
    },
    {
      "type": "simple_column",
      "alias": "breast_exam",
      "column": "a.breast_exam"
    },
    {
      "type": "simple_column",
      "alias": "fgm",
      "column": "a.fgm_done"
    },
    {
      "type": "simple_column",
      "alias": "fgm_complications",
      "column": "a.fgm_complications"
    },
    {
      "type": "simple_column",
      "alias": "haemoglobin",
      "column": "a.haemoglobin"
    },
    {
