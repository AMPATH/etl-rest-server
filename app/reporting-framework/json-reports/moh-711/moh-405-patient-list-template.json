{
  "name": "moh_405_patient_list_template",
  "version": "1.0",
  "tag": "moh_405_patient_list_template",
  "description": "moh_405_patient_list_template",
  "sources": [
    {
      "table": "etl.flat_mnch_summary",
      "alias": "a"
    },
    {
      "table": "amrs.person",
      "alias": "pn",
      "join": {
        "type": "LEFT",
        "joinCondition": "pn.person_id = a.person_id"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "anc_number",
      "join": {
        "type": "INNER",
        "joinCondition": "anc_number.patient_id = a.person_id AND anc_number.identifier_type = 48"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "nupi",
      "join": {
        "type": "INNER",
        "joinCondition": "nupi.patient_id = a.person_id AND nupi.identifier_type = 45"
      }
    },
    {
      "table": "amrs.person_name",
      "alias": "person_name",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = person_name.person_id AND (person_name.voided IS NULL || person_name.voided = 0) AND person_name.preferred = 1"
      }
    },
    {
      "table": "amrs.person_attribute",
      "alias": "attribute",
      "join": {
        "type": "LEFT",
        "joinCondition": "attribute.person_id = a.person_id AND attribute.person_attribute_type_id = 10"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "amrsId",
      "join": {
        "type": "INNER",
        "joinCondition": "a.person_id = amrs.patient_id AND (amrs.voided IS NULL || amrs.voided = 0) AND amrs.identifier_type = 8"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "obs",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = obs.person_id AND obs.concept_id in (10926, 10927, 2327, 12019)"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "ob",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = ob.person_id AND ob.concept_id = 12019"
      }
    },
    {
      "table": "amrs.obs",
      "alias": "oc",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = oc.person_id AND oc.concept_id = 1357"
      }
    },
    {
      "table": "amrs.person_address",
      "alias": "pa",
      "join": {
        "type": "LEFT",
        "joinCondition": "a.person_id = pa.person_id"
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "patient_uuid",
      "column": "pn.uuid"
    },
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "a.person_id"
    },
    {
      "type": "simple_column",
      "alias": "date_of_visit",
      "column": "a.encounter_datetime"
    },
    {
      "type": "simple_column",
      "alias": "anc_number",
      "column": "anc_number.identifier"
    },
    {
      "type": "simple_column",
      "alias": "nupi",
      "column": "nupi.identifier"
    },
    {
      "type": "simple_column",
      "alias": "amrs_id",
      "column": "amrsId.identifier"
    },
    {
      "type": "simple_column",
      "alias": "number_of_anc_visits",
      "column": "a.anc_visit_no"
    },
    {
      "type": "derived_column",
      "alias": "full_name",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": " CONCAT_WS(' ', COALESCE(person_name.given_name, ''), COALESCE(person_name.middle_name, ''), COALESCE(person_name.family_name, ''))"
      }
    },
    {
      "type": "simple_column",
      "alias": "date_of_birth",
      "column": "pn.birthdate"
    },
    {
      "type": "derived_column",
      "alias": "age",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "timestampdiff(year,pn.birthdate,a.encounter_datetime)"
      }
    },
    {
      "type": "simple_column",
      "alias": "county_sub_county",
      "column": "pa.county_district"
    },
    {
      "type": "simple_column",
      "alias": "village_estate_landmark",
      "column": "pa.city_village"
    },
    {
      "type": "simple_column",
      "alias": "phone_number",
      "column": "attribute.value"
    },
    {
      "type": "simple_column",
      "alias": "marital_status",
      "column": "null"
    },
    {
      "type": "simple_column",
      "alias": "parity",
      "column": "a.parity"
    },
    {
