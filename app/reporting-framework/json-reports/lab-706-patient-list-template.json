{
  "name": "lab-706-patient-list-template",
  "version": "1.0",
  "tag": "lab-706-patient-list-template",
  "description": "Patient list dataset for Lab MOH 706 report drill-down",
  "uses": [],
  "sources": [
    {
      "table": "etl.flat_moh_706_report",
      "alias": "t1"
    },
    {
      "table": "amrs.person_name",
      "alias": "pn",
      "join": {
        "type": "INNER",
        "joinCondition": "t1.person_id = pn.person_id AND pn.voided = 0"
      }
    },
    {
      "table": "amrs.person_address",
      "alias": "pa",
      "join": {
        "type": "LEFT OUTER",
        "joinCondition": "t1.person_id = pa.person_id AND pa.voided = 0"
      }
    },
    {
      "table": "amrs.person_attribute",
      "alias": "pat",
      "join": {
        "type": "LEFT",
        "joinCondition": "t1.person_id = pat.person_id AND pat.person_attribute_type_id = 10 AND pat.voided = 0"
      }
    },
    {
      "table": "amrs.patient_identifier",
      "alias": "pi",
      "join": {
        "type": "LEFT OUTER",
        "joinCondition": "t1.person_id = pi.patient_id AND pi.voided = 0"
      }
    },
    {
      "table": "amrs.encounter",
      "alias": "e",
      "join": {
        "type": "LEFT OUTER",
        "joinCondition": "t1.encounter_id = e.encounter_id"
      }
    },
    {
      "table": "amrs.users",
      "alias": "u",
      "join": {
        "type": "LEFT OUTER",
        "joinCondition": "e.creator = u.user_id"
      }
    },
    {
      "table": "amrs.provider",
      "alias": "prov",
      "join": {
        "type": "LEFT OUTER",
        "joinCondition": "u.person_id = prov.person_id"
      }
    },
    {
      "table": "amrs.person_name",
      "alias": "prov_name",
      "join": {
        "type": "LEFT OUTER",
        "joinCondition": "prov.person_id = prov_name.person_id AND prov_name.voided = 0"
      }
    }
  ],
  "columns": [
    {
      "type": "simple_column",
      "alias": "person_id",
      "column": "t1.person_id"
    },
    {
      "type": "simple_column",
      "alias": "uuid",
      "column": "t1.uuid"
    },
    {
      "type": "simple_column",
      "alias": "encounter_id",
      "column": "t1.encounter_id"
    },
    {
      "type": "simple_column",
      "alias": "date",
      "column": "DATE_FORMAT(t1.test_datetime, '%d/%m/%Y')"
    },
    {
      "type": "simple_column",
      "alias": "opd_ip_ref_no",
      "column": "pi.identifier"
    },
    {
      "type": "derived_column",
      "alias": "lab_no",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "t1.encounter_id"
      }
    },
    {
      "type": "derived_column",
      "alias": "revisit_no",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "NULL"
      }
    },
    {
      "type": "derived_column",
      "alias": "full_name",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "CONCAT(COALESCE(pn.given_name, ''), ' ', COALESCE(pn.middle_name, ''), ' ', COALESCE(pn.family_name, ''))"
      }
    },
    {
      "type": "derived_column",
      "alias": "age",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "TIMESTAMPDIFF(YEAR, p.birthdate, t1.test_datetime)"
      }
    },
    {
      "type": "simple_column",
      "alias": "sex",
      "column": "p.gender"
    },
    {
      "type": "derived_column",
      "alias": "county_sub_county",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "CONCAT(COALESCE(pa.county_district, ''), ' / ', COALESCE(pa.address6, ''))"
      }
    },
    {
      "type": "derived_column",
      "alias": "village_estate_landmark",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "COALESCE(pa.address2, pa.city_village, '')"
      }
    },
    {
      "type": "simple_column",
      "alias": "telephone_number",
      "column": "pat.value"
    },
    {
      "type": "derived_column",
      "alias": "clinician_name",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "CONCAT(COALESCE(prov_name.given_name, ''), ' ', COALESCE(prov_name.family_name, ''))"
      }
    },
    {
      "type": "simple_column",
      "alias": "date_sample_analysed",
      "column": "DATE_FORMAT(t1.test_datetime, '%d/%m/%Y')"
    },
    {
      "type": "derived_column",
      "alias": "testing_officer",
      "expressionType": "simple_expression",
      "expressionOptions": {
        "expression": "CONCAT(COALESCE(prov_name.given_name, ''), ' ', COALESCE(prov_name.family_name, ''))"
      }
    },
    {
      "type": "simple_column",
      "alias": "location",
      "column": "l.name"
    },
    {
      "type": "simple_column",
      "alias": "location_uuid",
      "column": "l.uuid"
    },
    {
      "type": "simple_column",
      "alias": "location_id",
      "column": "t1.location_id"
    }
  ],
  "groupBy": {
    "columns": ["t1.person_id"]
  }
}
